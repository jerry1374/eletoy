---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const items = await getCollection('products');
  return items.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const title = entry.data.title ?? entry.id;
---
<Base title={title} description={entry.data.summary}>
  <article class="entry">
    <div class="entry-head">
      <div class="entry-meta">
        <span class="readout">{entry.data.model ?? 'Product'}</span>
        {entry.data.link && <a class="readout" href={entry.data.link}>购买 / 详情 →</a>}
      </div>
      <h1>{title}</h1>
    </div>
    {entry.data.cover && (
      <div class="cover"><img src={entry.data.cover} alt={title} /></div>
    )}
    <div class="prose">
      <Content />
    </div>
    <a class="back" href="/products/">← 返回 Products</a>
  </article>
</Base>
