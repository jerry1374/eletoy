---
import Base from '../../layouts/Base.astro';
import EntryCard from '../../components/EntryCard.astro';
import { getCollection } from 'astro:content';

const items = (await getCollection('products'))
  .filter((e) => !e.data.draft)
  .sort((a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0));
---
<Base title="Products" description="ELETOY 产品与资料">
  <div class="page-head">
    <span class="readout">Hardware & Manuals</span>
    <h1>Products</h1>
  </div>
  {items.length ? (
    <div class="grid">
      {items.map((e) => (
        <EntryCard
          href={`/products/${e.id}/`}
          title={e.data.title ?? e.id}
          date={e.data.date}
          image={e.data.image}
          summary={e.data.summary}
          tag={e.data.model ?? 'Product'}
        />
      ))}
    </div>
  ) : (
    <div class="empty">还没有产品。</div>
  )}
</Base>
