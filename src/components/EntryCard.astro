---
interface Props {
  href: string;
  title: string;
  date?: Date;
  cover?: string;
  summary?: string;
  tag?: string;
}
const { href, title, date, cover, summary, tag } = Astro.props;
const dateStr = date
  ? `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}-${String(date.getDate()).padStart(2, '0')}`
  : undefined;
---
<a class="card" href={href}>
  <div class="thumb">
    {cover ? <img src={cover} alt={title} loading="lazy" /> : <span class="ph">◻</span>}
  </div>
  <div class="body">
    <div class="meta">
      {tag && <span class="readout">{tag}</span>}
      {dateStr && <span class="readout">{dateStr}</span>}
    </div>
    <span class="card-title">{title}</span>
    {summary && <p class="summary">{summary}</p>}
  </div>
</a>
